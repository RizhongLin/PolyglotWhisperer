# PolyglotWhisperer — API keys for cloud providers
# Copy to .env and fill in your keys. Shell env vars take precedence.
# LiteLLM auto-selects the key matching the model prefix (openrouter/, groq/, etc.)

# OpenRouter — wide model range, competitive pricing (LLM)
# OPENROUTER_API_KEY=sk-or-v1-...

# Groq — fast inference, cheapest Whisper STT
# GROQ_API_KEY=gsk_...

# OpenAI — Whisper + GPT models
# OPENAI_API_KEY=sk-...

# Anthropic — Claude models
# ANTHROPIC_API_KEY=sk-ant-...

# Fireworks AI — Whisper STT + LLM
# FIREWORKS_AI_API_KEY=fw_...

# DeepSeek — direct API (strong multilingual/CJK)
# DEEPSEEK_API_KEY=sk-...
